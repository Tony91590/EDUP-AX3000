# Monitoring
CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_collectd=y
CONFIG_PACKAGE_collectd-mod-cpu=y
CONFIG_PACKAGE_collectd-mod-memory=y
CONFIG_PACKAGE_collectd-mod-network=y
CONFIG_PACKAGE_collectd-mod-load=y
CONFIG_PACKAGE_collectd-mod-thermal=y
CONFIG_PACKAGE_luci-i18n-statistics-fr=y

# Informations système
CONFIG_PACKAGE_luci-mod-status=y

# Wake-on-LAN
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-i18n-wol-fr=y

# Dynamic DNS
CONFIG_PACKAGE_ddns-scripts=y
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-i18n-ddns-fr=y

# QoS moderne (SQM)
CONFIG_PACKAGE_sqm-scripts=y
CONFIG_PACKAGE_luci-app-sqm=y
CONFIG_PACKAGE_luci-i18n-sqm-fr=y

# Gestion des certificats
CONFIG_PACKAGE_ca-certificates=y

# Outils réseau utiles
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_ethtool=y

# USB (si ton matériel le supporte)
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_kmod-fs-ext4=y

# MiniUPnP
CONFIG_PACKAGE_miniupnpd-nftables=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-fr=y

# Argon
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-i18n-argon-config-fr=y

# Français
CONFIG_PACKAGE_luci-i18n-base-fr=y
CONFIG_PACKAGE_luci-i18n-firewall-fr=y
CONFIG_PACKAGE_luci-i18n-package-manager-fr=y
CONFIG_PACKAGE_luci-i18n-attendedsysupgrade-fr=y
CONFIG_PACKAGE_luci-i18n-ddns-fr=y
CONFIG_PACKAGE_luci-i18n-sqm-fr=y
CONFIG_PACKAGE_luci-i18n-statistics-fr=y
CONFIG_PACKAGE_luci-i18n-upnp-fr=y
CONFIG_PACKAGE_luci-i18n-wol-fr=y
